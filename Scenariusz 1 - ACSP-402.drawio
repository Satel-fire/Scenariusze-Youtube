<mxfile host="app.diagrams.net">
  <diagram name="Strona-1" id="z8KAe0LmT8Zc7_pRFNcT">
    <mxGraphModel dx="1193" dy="2242" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="0EHHFv7u1sgkDXgEne3z-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div align=&quot;left&quot;&gt;Widok na samą obudowę, zmieniany na płytę główną, instalator wykonuje po kolei czynności, lektor czyta:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;1.&amp;nbsp; Zaczynamy od powieszenia centralę na ścianie, zmiana kamery na centralę&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;2. Wprowadzamy przewody i podłączamy:&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;a) przewód zasilający 230V (komentarz: instalacja zasilająca musi spełniać wymogi rozporządzenia Ministra Infrastruktury w sprawie WT jakim powinny odpowiadać budynki i ich usytuowanie),&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;b) przewody linii dozorowych (komentarz: najbardziej powszechnym rodzajem jest instalacja pętlowa, możliwe jest również wykonanie topologii promieniowej lub pętlowej z odgałęzieniami - na części ekranu rysunek)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;c) linia sygnałowe i wyjścia sterujące (komentarz: z wyjścia FRE TX możemy w razie konieczności stworzyć dodatkowe wyjście sygnałowe, wyjścia sygnałowe oraz uszkodzeń i pożaru wymagają stosowania rezystorów końcowych&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;d) wejścia kontrolne (również mogą wymagać rezystorów końca linii)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;d) podłączamy akumulator do centrali (komentarz:&amp;nbsp;Jako źródło zasilania rezerwowego stosowany jest pojedynczy akumulator 12V)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;e) podłączenie przewodu USB do centrali komputera (komentarz: do konfiguracji używamy przewodu USB A-B tzw. drukarkowego&lt;/div&gt;" vertex="1">
          <mxGeometry height="460" width="330" x="1080" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Jak wygląda nowoczesny system pozarowy? Na przykładzie centrali ACSP - 402 od Satel&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="330" x="1080" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Wstęp do filmu&lt;/div&gt;&lt;div&gt;20 s&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="920" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na centralę z elementami na tablicy, stojący lektor wita się i mówi:&lt;/div&gt;&lt;div&gt;Witaj na kanale Satel&lt;/div&gt;&lt;div&gt;&quot;W obecnych czasach bezpieczeństwo pożarowe staje się niezbędną koniecznością. Firma Satel istniejąca od 35 lat, to lider w dziedzinie systemów zabezpieczeń&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;W dzisiejszym filmie, pokażemy Wam centralę adresowalną ACSP-402, pokażemy jej poprawny montaż i podłączenie przewodów&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="1080" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Opis urządzenia&lt;/div&gt;&lt;div&gt;45 s&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="920" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div align=&quot;left&quot;&gt;Widok na samą centralę, już bez widocznego lektora, można strzałkami pokazywać lub śrubokrętem lokalizację złączy&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Centrala ACSP-402 jest centralą adresowalnego systemu sygnalizacji pożarowej, posiadającą:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 2 linie dozorowe do 128 urządzeń każda&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 256 stref dozorowych&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 2 wyjścia napięciowe do sygnalizatorów&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- dedykowane wyjścia transmisji pożaru i uszkodzenia&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 4 wejscia kontrolne i 8 wyjść przekaźnikowych bezpotencjałowych&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- tory transmisji RS485 do podłaczenia urządzeń zdalnej obsługi i sygnalizacji oraz modułów komunikacyjnych&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- złącza zasilajace i USB&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="330" x="1080" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Podłączenie i topologia&lt;/div&gt;&lt;div&gt;120-180 s&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="920" y="940" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Intro filmu&lt;/div&gt;&lt;div&gt;3 s&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="920" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Tekst Polski" vertex="1">
          <mxGeometry height="60" width="330" x="1080" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="Tekst Angielski" vertex="1">
          <mxGeometry height="60" width="330" x="1450" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Scenariusz 1 - ACSP-402" vertex="1">
          <mxGeometry height="60" width="700" x="1080" y="-120" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Zakończenie i zaproszenie&lt;/div&gt;&lt;div&gt;30 s&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="920" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) W tym momencie przewody zostały poprawnie podłączone do centrali&lt;/div&gt;&lt;div&gt;2) Oczywiście teraz pozostało nam jej zaprogramowanie i identyfikacja urządzeń, które podłączyliśmy, ale na to zapraszamy do kolejnego odcinka&lt;/div&gt;&lt;div&gt;3) Jeśli materiał Ci się podobał, zostaw kciuk w górę. Masz uwagi, sugestie lub propozycje odcinka? Zostaw komentarz pod filmem. Dzięki za uwagę i do zobaczenia&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="1080" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Satel Fire jakaś animacja wieńcząca dzieło" vertex="1">
          <mxGeometry height="60" width="700" x="1080" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Zakonczenie filmu&lt;/div&gt;&lt;div&gt;2 s&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="920" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) At this moment, all wires are firmly connected to fire panel&lt;/div&gt;&lt;div&gt;2) Obviosly now all we have to is add our devices to the panel and set all functions that are needed. But this will be covered in our next video, for which you are invited&amp;nbsp;&lt;/div&gt;&lt;div&gt;3) If you liked this material, leave a thumbs up. Have a suggestion, video proposition ? Leave a comment and subscribe to this channel, not to miss next episode.Stay safe and see you in the next video&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="1450" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="How does a modern fire system looks like? Looks like ACSP-402 by Satel" vertex="1">
          <mxGeometry height="60" width="330" x="1450" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-18" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Widok na centralę z elementami na tablicy, stojący lektor wita się i mówi:&lt;/div&gt;&lt;div&gt;&quot;Welcome to Satel channel&lt;/div&gt;&lt;div&gt;Nowadays fire safety is becoming something more than a mandatory obligation. For the past 35 years, Satel has become a leader in safety systems&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;In today&#39;s video, we will show you ACSP-402 addressable fire panel, how to assemble it and correctly connect wires&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="1450" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div align=&quot;left&quot;&gt;Widok na samą centralę, już bez widocznego lektora, można strzałkami pokazywać lub śrubokrętem lokalizację złączy&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;ACSP-402&amp;nbsp;is addresabble fire alarm control panel, featuring:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 2 loops supporting up to 128 devices per loop&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- up to 256 detection zones&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 2 signal lines&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- transmission outputs for fire alarm and fault signal&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- 4 inputs and 8 relay outputs&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- RS485 communication bus for connecting modules and repeater panels&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- USB, power supply and battery connection&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="330" x="1450" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0EHHFv7u1sgkDXgEne3z-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div align=&quot;left&quot;&gt;Widok na samą obudowę, zmieniany na płytę główną, instalator wykonuje po kolei czynności, lektor czyta:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;1.&amp;nbsp; Installation begins from hanging the control panel on the wall&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;2. Wires are ready to be connected, starting from&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;a) power supply wire 230V (komentarz: power supply instalation should be safe and prepared accoring to your country&#39;s law and best practices)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;b) detection lines wires (komentarz: the most common type of topology are Loops, but it is also possible to use Radial or Loop with side lines - na części ekranu rysunek)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;c) signal and transmission line wires (komentarz: in case of need, you can use fire alarm transmission line as additional, 3rd signal line. Please note that signal lines and fault signal lines require termination resistors)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;d) inputs (komentarz: inputs might also require termination resistors)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;d) battery conection (komentarz: ACSP control panels uses single 12V battery as a backup power supply)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;e) USB cord connection (komentarz: to configure fire control panel from your laptop, we use standard USB A-B cord, so called printer cable)&lt;/div&gt;" vertex="1">
          <mxGeometry height="460" width="330" x="1450" y="910" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div align=&quot;left&quot;&gt;Widok na moduł i centralę, instalator wykonuje po kolei czynności, lektor czyta:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;1. Przykręcamy moduł ACSP-ETH od spodu modułu płyty głównej&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;2. Łączymy moduł z centralą przy pomocy magistrali RS-485 (obrazek nr3 z instrukcji na części ekranu)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;3. Podłączamy kabel sieciowy i zasilanie (obrazek nr4 z instrukcji na części ekranu)&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Przechodzimy teraz do konfiguracji modułu w programie ACSP Soft&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;(Odpalamy widok monitora i następuje konfiguracja)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;1. W zakładce Urządzenia RS-485, zaznaczamy obsługę modułu, dalej jeśli router ma automatycznie przydzielić adres IP oraz DNS to zaznaczamy te dwie opcje. ( komentarz: jeśli mamy podany ustalony adres z administratorem sieci, wyłączamy DHCP i wpisujemy dane otrzymane z działu IT)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;2. W polu Aplikacja VAPSP zaznaczamy jej obsługę, wpisujemy hasło dla zwykłego użytkownika oraz serwisowe, wpisujemy port komunikacyjny (komentarz: jeśli wpiszemy port 80 to później w aplikacji nie musimy pamiętać o wpisaniu portu, jednak dla potrzeb przekierowania na zewnątrz należy ten port przekierować na inny port zewnętrzny najlepiej z zakresu 5-io cyfrowego lub użyć połączeń typu VPN)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;3. Jeśli chcemy korzystać z opcji synchronizacji czasu z serwerem NTP, musimy ją zaznaczyć oraz podać adres serwera czasu&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;4. Jeśli chcemy by centrala wysyłała powiadomienie email musimy skonfigurować pole email. Uruchamiamy obsługę powiadomień email, podajemy parametry dla konta poczty wychodzącej, wybieramy czy jest wymagane uwierzytelnienie czy też nie, podajemy do czterech adresów email odbiorców, tworzymy przydział zdarzeń do maili, podajemy okres zwłoki wysłania powiadomień, jest to czas przez który centrala zbiera zdarzenia do wysłania ( komentarz: nie dotyczy to zdarzeń alarmowych, które są wysyłane bez zbędnej zwłoki). Konfigurujemy wysyłanie raportu testowego na określony adres email, oraz okres raportowania. Emaile diagnostyczne wychodzą pierwszego dnia okresu raportowania. Po skończonej konfiguracji zapisujemy konfigurację klikając na pole Wyślij a następnie zapisujemy do Pamięci nieulotnej.&lt;/div&gt;" vertex="1">
          <mxGeometry height="650" width="330" x="1910" y="910" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Jak skonfigurować moduł ETH aby pracował z centralą ACSP-402 ?" vertex="1">
          <mxGeometry height="60" width="330" x="1910" y="40" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na centralę z elementami na tablicy, stojący lektor wita się i mówi:&lt;/div&gt;&lt;div&gt;Witaj na kanale Satel&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;W dzisiejszym filmie, pokażemy Wam moduł ACSP-ETH, pokażemy jego poprawne podłączenie i konfigurację&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="1910" y="120" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div align=&quot;left&quot;&gt;Widok na centralę i moduł ETH, już bez widocznego lektora, można strzałkami pokazywać lub śrubokrętem lokalizację złączy&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Moduł ethernetowy ACSP-ETH na płytce elektroniki posiada:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- gniazdo RJ-45 do podłączenia sieci LAN. Zielona dioda świeci, gdy moduł jest podłączony do sieci. Zółta miga podczas transmisji danych&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- przycisk do resetowania modułu&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- diody D1 oraz D2. Dioda D1 świeci, gdy moduł jest połączony z siecią. Dioda D2 świeci gdy moduł jest zasilony, a miga gdy trwa komunikacja&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- Zaciski RS-485 i zasilanie&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="330" x="1910" y="350" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Tekst Polski" vertex="1">
          <mxGeometry height="60" width="330" x="1910" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="Tekst Angielski" vertex="1">
          <mxGeometry height="60" width="330" x="2280" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Scenariusz 2 - ACSP-ETH" vertex="1">
          <mxGeometry height="60" width="700" x="1910" y="-120" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) W tym momencie moduł zostały poprawnie podłączony do centrali&lt;/div&gt;&lt;div&gt;2) Mamy również ustawioną komunikację z programem&lt;/div&gt;&lt;div&gt;3)Jeśli materiał Ci się podobał, zostaw kciuk w górę. Masz uwagi, sugestie lub propozycje odcinka? Zostaw komentarz pod filmem. Dzięki za uwagę i do zobaczenia&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="1910" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Satel Fire jakaś animacja wieńcząca dzieło" vertex="1">
          <mxGeometry height="60" width="700" x="1910" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) At this moment, our module is firmly connected to control panel&lt;/div&gt;&lt;div&gt;2) The communication with the panel is also set up.&lt;/div&gt;&lt;div&gt;3) If you liked this material, leave a thumbs up. Have a suggestion, video proposition ? Leave a comment and subscribe to this channel, not to miss next episode.Stay safe and see you in the next video&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="2280" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="How to install ACSP-ETH ethernet module to fire panel ACSP-402 ?" vertex="1">
          <mxGeometry height="60" width="330" x="2280" y="40" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Widok na centralę z elementami na tablicy, stojący lektor wita się i mówi:&lt;/div&gt;&lt;div&gt;&quot;Welcome to Satel channel&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;In today&#39;s video, we will show you ethernet module ACSP-ETH, how to connect it and configure&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="2280" y="120" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div align=&quot;left&quot;&gt;Widok na centralę i moduł ETH, już bez widocznego lektora, można strzałkami pokazywać lub śrubokrętem lokalizację złączy&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;ACSP-ETH has on the board:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- RJ-45 socket for connecting LAN network. Green LED is on when module is connected to network, Yellow LED is flashing during data transmission&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- reset button&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;- D1 and D2 LED. D1 LED is on, when module is connected to network, D2 LED is on when power supply is present, LED is flashing during communication&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;-&amp;nbsp;RS485 communication bus and power inputs&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="330" x="2280" y="350" as="geometry" />
        </mxCell>
        <mxCell id="6_1prXv-E_gUM5x_UOCS-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;br&gt;&lt;div align=&quot;left&quot;&gt;Widok na moduł i centralę, instalator wykonuje po kolei czynności, lektor czyta:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;1. Screw the ACSP-ETH module to the bottom of the control panel&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;2. Connect the module to the control panel using the RS-485 bus (obrazek nr3 z instrukcji na części ekranu)&lt;div align=&quot;left&quot;&gt;3. Connect the module to the Ethernet network and to power supply (obrazek nr4 z instrukcji na części ekranu)&amp;nbsp;&lt;/div&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Let&#39;s switch now to ACSP Soft to configure our module&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;(Odpalamy widok monitora i następuje konfiguracja)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;1. In the RS-485 devices page, enable ACSP-ETH module. If you want adress and DNS to be automatically given by your router, select these options. If you have dedicated IP address, specify it below.&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;2. To use Virtual APSP later on, enable it and set password for standard user and service team. Default port is 80 and then we don&#39;t need to type it during logging in. If you want to redirect connection outside your network, it is recommended to change it to 5 digit number or use VPN&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;3. If we want to use NTP time synchronization, enable it and type server address. This is usually recommended to use&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;4. If we want to set E-mail messaging, enable it and start configuration. Type SMTP parameters and authentication if required. Now, we can select up to 4 e-mail recipients, selecting what types of events are being sent.&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Period selection means for how long the control panel will collect and send grouped events raport. This does not refer to Fire Alarm - they are being sent instantly.&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Diagnostic e-mail is set separately, with the same logic.&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;After succesful confirugation, we click Upload and then Write to non-volatile memory&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="650" width="330" x="2280" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;br&gt;&lt;div align=&quot;left&quot;&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Widok na gniazdo i przewody, czujka i WZ leżą obok, już bez widocznego &lt;br&gt;lektora, można strzałkami pokazywać lub śrubokrętem lokalizację złączy&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Podstawę przymocowujemy do sufitu i przygotowujemy przewody. Przewody mogą być wprowadzone przez dno lub boki podstawy&amp;nbsp;(obrazki 1 i 2 z instrukcji) &lt;br&gt;Możliwy jest&amp;nbsp;także montaż przy użyciu podstawy przemysłowej PDB-100 (rysunek 3)&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Następnie do gniazda podłączamy przewody początku i końca pętli (obrazek 5)&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Komentarz:&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Zwróć uwagę na długości żył kabla i żyły ochronnej, Przewody nie powinny być zbyt długie, aby uniknąć przypadkowych przywarć do styków&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;Jeśli do czujki ma być podłączony wskaźnik zadziałania WZ-110, podłączamy go zgodnie z instrukcja (rysunke 6)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="330" x="2740" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Jak podłączyć gniazdo DB-400, czujkę dymu i ciepła DMP-400 i wskaźnik WZ-110 z centralą ACSP-402 ?" vertex="1">
          <mxGeometry height="60" width="330" x="2740" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na centralę z elementami na tablicy, stojący lektor wita się i mówi:&lt;/div&gt;&lt;div&gt;Witaj na kanale Satel&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;W dzisiejszym filmie, przedstawimy Wam rodzinę adresowalnych czujek dymu i ciepła, pokażemy także jak zamontować gniazdo, czujkę i wskaźnik zadziałania&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="2740" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;br&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Widok na czujkę DMP-400,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;już bez widocznego lektora.&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tekst lektora:&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Punktowa&lt;br&gt; wieledetektorowa czujka dymu i ciepła DMP-400 wykrywa pożary płomieniowe i bezpłomieniowe od TF1 do TF6 i TF8. Alarmy pożarowe generowane są z niezależnych detektorów dymu i ciepła oraz ze współpracy detektora ciepła i detektora dymu, w chwili pojawienia się temperatury, która nie pozwala na osiągniecie parametrów pozwalających na wygenerowanie pożaru, czułość detekcji dymu wzrasta.&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Widok na czujkę DRP-400, &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;już bez widocznego lektora.&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tekst lektora:&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Rozproszeniowa&lt;br&gt; punktowa czujka dymu DRP-400 wykrywa pożary płomieniowe i bezpłomieniowe od TF2 do TF5 i TF8.&amp;nbsp;Podobnie jak czujka DMP-400 została&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;wyposażona&lt;br&gt; w funkcje kompensacji dryftu zabrudzenia, czyli mechanizm automatycznej korekty progu zadziałania wraz z postępującym zabrudzeniem komory &lt;br&gt;optycznej czujki dymu. Algorytm wykrywa systematyczne, powolne zabrudzanie komory optycznej czujki i dostosowuje próg zadziałania czujki w celu zachowania odpowiedniej czułości czujki.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Widok na czujkę DCP-400, &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;już bez widocznego lektora.&lt;/span&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tekst lektora:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Punktowa czujka ciepła DCP-400 klasy&amp;nbsp; A1R&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;przeznaczona&amp;nbsp;&lt;br&gt; jest do wykrywania pożarów płomieniowych w których temperatura przy czujce jest w granicach od 55 do 65 C lub występuje duża prędkość narastania temperatur.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="510" width="330" x="2740" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Tekst Polski" vertex="1">
          <mxGeometry height="60" width="330" x="2740" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="Tekst Angielski" vertex="1">
          <mxGeometry height="60" width="330" x="3110" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Scenariusz 3 - Adresowalne czujki dymu i ciepła" vertex="1">
          <mxGeometry height="60" width="700" x="2740" y="-120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) W tym momencie czujka i wskaźnik zadziałania zostały poprawnie podłączony do centrali&lt;/div&gt;&lt;div&gt;2)&amp;nbsp;Oczywiście teraz pozostało nam identyfikacja &lt;br/&gt;urządzeń w systemie, ale na to zapraszamy do kolejnego odcinka&lt;/div&gt;&lt;div&gt;3)Jeśli materiał Ci się podobał, zostaw kciuk w górę. Masz uwagi, sugestie lub propozycje odcinka? Zostaw komentarz pod filmem. Dzięki za uwagę i do zobaczenia&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="2740" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Satel Fire jakaś animacja wieńcząca dzieło" vertex="1">
          <mxGeometry height="60" width="700" x="2740" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) At this moment, our sensor and indicator are correctly connected to the control panel&lt;/div&gt;&lt;div&gt;2)&amp;nbsp; Obviosly now all we have to is add our devices to the panel. But this will be covered in our next video.&lt;/div&gt;&lt;div&gt;3) If you liked this material, leave a thumbs up. Have a suggestion, video proposition ? Leave a comment and subscribe to this channel, not to miss next episode.Stay safe and see you in the next video&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="3110" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="How to install DB-400 dectector base, DMP-400 smoke and heat detector and WZ-110 alarm indicator" vertex="1">
          <mxGeometry height="60" width="330" x="3110" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Widok na centralę z elementami na tablicy, stojący lektor wita się i mówi:&lt;/div&gt;&lt;div&gt;&quot;Welcome to Satel channel&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;In today&#39;s video, we will present you family of addressable smoke and heat detectors, we will also show how to install detector base and connect alarm indicator&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="3110" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;dodac tlumaczenie&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="330" x="3110" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;dodac tlumaczenie&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="330" x="3110" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Aby poprawnie zamontować czujkę, w pomieszczeniu które chcesz chronić wybierz miejsce na suficie możliwie jak najbliżej środka. Czujka powinna być instalowana w pomieszczeniach zamkniętych, o normalnej wilgotności powietrza. Nie instaluj czujki na zewnątrz.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Zalecenia instalacyjne znajdziesz w dołączonej instrukcji&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Zdejmij plastikową osłonę przeciwpyłową (nie wyrzucaj jej, może przydać się w trakcie remontu)&lt;/div&gt;&lt;div&gt;2. Zdejmij pokrywę czujki i przymocuj podstawę do sufitu przy użyciu kołków montażowych&amp;nbsp;&lt;/div&gt;&lt;div&gt;3. Zamontuj baterię w czujce i założ pokrywę. Pamietaj - nie zamontujesz czujki bez włożonej baterii cR123A&lt;/div&gt;&lt;div&gt;4. Wciśnij przycisk i sprawdź działanie czujki. Po chwili usłyszysz alarm pożarowy. Wciśnij ponownie przycisk, aby skasować alarm.&lt;/div&gt;&lt;div&gt;Uwaga: Przez 5 minut po skasowaniu alarmu pożarowego, funkcja wykrywania dymu jest zablokowana&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Warto wiedzieć:&lt;/div&gt;&lt;div&gt;Wskaźniki LED i sygnalizator dźwiękowy sygnalizują:&lt;/div&gt;&lt;div&gt;- alarm pożarowy - świecenie i ciągły dzwięk przez 5 minut&lt;/div&gt;&lt;div&gt;- słabą baterię - 3 krótkie błyski/dźwięki co 30 sekund. Czujka powinna w takim trybie wytrzymać do 2 tygodni pracy&lt;/div&gt;&lt;div&gt;- zabrudzenie komory dymu - 2 błyski co 30 sekund, bez dźwięku&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Aby wyczuścić komorę dymu:&lt;/div&gt;&lt;div&gt;1. Zdejmij czujkę z podstawy i wyjmiij baterię&lt;/div&gt;&lt;div&gt;2. Odłącz wtyczkę sygnalizatora, po czym odchyl blokadę i przekręć moduł elektroniki w kierunku przeciwnym od ruchu wskazówek zegara&lt;/div&gt;&lt;div&gt;3. Odchyl zaczep i zdejmij pokrywę komory dymu&lt;/div&gt;&lt;div&gt;4. Wyczyść pędzelkiem lub sprężonym powietrzem oba elementy. Zwróc uwagę na zagłębienia, w których są diody - muszą być czyste&lt;/div&gt;&lt;div&gt;5. Złóż urządzenie, włóż baterię i przetestuj działanie&lt;/div&gt;" vertex="1">
          <mxGeometry height="650" width="330" x="3570" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="SDA-250 -autonomiczna czujka dymu. Montaż i obsługa" vertex="1">
          <mxGeometry height="60" width="330" x="3570" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na czujkę zamontowaną na a&#39;la suficie, robimy prawdziwy dym i czujka zaczyna sygnalizować alarm, po czym następuje powolne cięcie i dalsza treść&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Witaj na kanale Satel&lt;/div&gt;&lt;div&gt;Całe szczęście w naszym studio była obecna czujka, która ostrzegła nas przed zagrożeniem pożarowym.&lt;/div&gt;&lt;div&gt;W dzisiejszym filmie, przedstawimy Wam jak poprawnie zamontować i obsługiwać autonomiczną czuję dymu w Twoim mieszkaniu.&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="3570" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-18" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="Z myślą o bezpieczeństwie Satel stworzył niezawodną i łatwą w użyciu, autonomiczną czujke dymu SDA-250. Urządzenie spełnia restrykcyjne wymogi normy EN 14604 i tym samym zapewnia precyzyjny pomiar i natychmiastową reakcję na zagrożenie. Na jednej baterii może pracować nawet 10 lat, co daje Ci spokój na długie lata." vertex="1">
          <mxGeometry height="280" width="330" x="3570" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Tekst Polski" vertex="1">
          <mxGeometry height="60" width="330" x="3570" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="Tekst Angielski" vertex="1">
          <mxGeometry height="60" width="330" x="3940" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Scenariusz 4 - SDA-250" vertex="1">
          <mxGeometry height="60" width="700" x="3570" y="-120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-22" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na czujkę na suficie, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) Czujka jest znowu gotowa do pracy&amp;nbsp;&lt;/div&gt;&lt;div&gt;2) Dzięki temu prostemu urządzeniu, wielokrotnie wzrasta szansa na wykrycie pożaru w jego wczesnej fazie.&amp;nbsp;&lt;/div&gt;&lt;div&gt;3)Jeśli materiał Ci się podobał, zostaw kciuk w górę. Masz uwagi, sugestie lub propozycje odcinka? Zostaw komentarz pod filmem. Dzięki za uwagę i do zobaczenia&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="3570" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Satel Fire jakaś animacja wieńcząca dzieło" vertex="1">
          <mxGeometry height="60" width="700" x="3570" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-24" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Chwilowy widok na gotową centralę, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) At this moment, our detector is ready again&lt;/div&gt;&lt;div&gt;2)&amp;nbsp; Thanks to this simple device, chance of avoiding fatal damage increases expodentially&lt;/div&gt;&lt;div&gt;3) If you liked this material, leave a thumbs up. Have a suggestion, video proposition ? Leave a comment and subscribe to this channel, not to miss next episode.Stay safe and see you in the next video&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="3940" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="SDA-250 - standalone smoke detector. Installation and maintance" vertex="1">
          <mxGeometry height="60" width="330" x="3940" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Widok na czujkę zamontowaną na a&#39;la suficie, robimy prawdziwy dym i czujka zaczyna sygnalizować alarm, po czym następuje powolne cięcie i dalsza treść&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Welcome to Satel channel&lt;/div&gt;&lt;div&gt;Fortuantelly, we had a detector in our studio, which had warned us about fire danger.&lt;/div&gt;&lt;div&gt;In today&#39;s video, we will show you how to properly install and use standalone smoke detector in your home&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="3940" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-27" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="Having your safety in mind, Satel have designed reliable and easy to use, standalone smoke detector SA-250. The device meets strict EN 14604 norm requirements and therefore gives its user precise detection and immediate reaction to fire danger. It works up to 10 yeard on a single battery, which let&#39;s you stay safe for an extended period of time" vertex="1">
          <mxGeometry height="280" width="330" x="3940" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-28" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;To properly install detector, chose celing location as close as possible to the center of the room. The detector should be installed indoors, in spaces wirh normal air humidity. Do not install the detector outdoors.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;All installation tips can be found in manual attached&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Remove the plastic dust cover (do not throw it away, may be useful during renovation and dusty works)&lt;/div&gt;&lt;div&gt;2. Remove detector from base and mount the base to the ceiling using anchors or screws&lt;/div&gt;&lt;div&gt;3. Install the CR123A battery and twist detector to install it. Important: The detector can&#39;t be installed without battery&lt;/div&gt;&lt;div&gt;4. Press the test/reset button and check if the device is working. A fire alarm should be generated. Press again to clear the alarm&lt;/div&gt;&lt;div&gt;Important: The smoke detection function will be blocked for 5 minutes after the alarm is cleared.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Good to know:&lt;/div&gt;&lt;div&gt;LED indicator and sounder indicates:&lt;/div&gt;&lt;div&gt;- fire alarm - continous beep and LED on for 5 minutes&lt;/div&gt;&lt;div&gt;- low battery - 3 short flashes and 3 short beeps every 30 seconds&lt;/div&gt;&lt;div&gt;- dirty smoke chamber - 2 short flashes every 30 seconds, no beep&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;To clear dirty smoke chamber:&lt;/div&gt;&lt;div&gt;1. Remove cover from the base and remove the battery&lt;/div&gt;&lt;div&gt;2. Disconnect the sounder plug, then pull the release lever and turn whole electronics module counter-clockwise&lt;/div&gt;&lt;div&gt;3. Release the mounting catch and remove the smoke chamber cover&lt;/div&gt;&lt;div&gt;4. Using a soft brush or compressed air, clean the labyrinth in the cover, as well as the base of the smoke chamber. Pay attention to the recesses where LEDs are installed.&lt;br&gt;8. Put the device together, put the battery in and use test/reset button&lt;/div&gt;" vertex="1">
          <mxGeometry height="650" width="330" x="3940" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Sposób podłączenia:&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;1.Z centrali P.Poż. wyprowadzamy przewód wielożyłowy służący do podłączenia wejść i wyjść pomiędzy urządzeniami, oraz przewodu&amp;nbsp;zasilającego 230V&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;2. Wprowadzamy przewód do obudowy OPU-4 lub 3P i montujemy ją przy centrali&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;3. Montujemy moduł komunikacyjny GSM-X, GPRS-A&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;4. W obudowie montujemy zasilacz APS-412&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;5. Podłączamy kabel zasilający 230V do zasilacza APS-412 a następnie do centrali pożarowej&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;6. Podłączamy przewód 3-żyłowy pomiędzy zasilaczem a modułem, podłączany&amp;nbsp;przewód akumulatorowy do zasilacza a następnie do akumulatora&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;7.Używając kabla wielożyłowego podłączamy wyjścia przekaźnikowe w centrali do wejść w module, oraz wyjście z modułu które będzie informowało o uszkodzeniu modułu do wejścia kontrolnego w centrali&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;8. Konfigurujemy centralę oraz moduł&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;9. Testujemy zaprogramowaną funkcjonalność wywołując alarm, uszkodzenie na centrali oraz uszkodzenie w samym module.&lt;/div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="650" width="330" x="4410" y="910" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;br&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;GSM-X, GPRS-A - podłączenie modułów do centrali ACSP-402, montaż i konfiguracja&lt;/div&gt;&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="330" x="4410" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na moduły:&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;Witaj na kanale Satel&lt;/div&gt;&lt;div&gt;Dziś przedstawimy&amp;nbsp;sposób podłączenia modułów GSM i GPRS do centrali pożarowej ACSP-402. Wyjaśnimy też różnice pomiędzy pracą z modułami i centralą&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="330" x="4410" y="120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Moduł GSM-X oraz GRPS-A to uniwersalne moduły komunikacyjne.Wykorzystamy je dzisiaj do przesłania informacji o alarmie pożarowym i uszkodzeniach na nasz telefon&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;aby zapewnić dodatkową kontrolę nad systemem pożarowym, poprzez powiadomienie głosowe, sms, clip w module GSM-X, lub sms i clip w module GPRS-A.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="330" x="4410" y="350" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b1ddf0;strokeColor=#10739e;" value="Tekst Polski" vertex="1">
          <mxGeometry height="60" width="330" x="4410" y="-40" as="geometry" />
        </mxCell>
