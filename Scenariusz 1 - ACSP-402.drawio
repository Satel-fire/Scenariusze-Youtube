          <mxGeometry height="60" width="330" x="4780" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-35" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Scenariusz 5 - GSM-X i ACSP-402" vertex="1">
          <mxGeometry height="60" width="700" x="4410" y="-120" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-36" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#b1ddf0;strokeColor=#10739e;" value="&lt;div&gt;Widok na centralę i moduł na ścianie, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) Nasz moduł został poprawnie podłączony i skonfigurowany&lt;/div&gt;&lt;div&gt;2) Mamy teraz możliwość uzyskania natychmiastowej informacji o alarmach i uszkodzeniach na zabezpieczonym obiekcie&amp;nbsp;&lt;/div&gt;&lt;div&gt;3)Jeśli materiał Ci się podobał, zostaw kciuk w górę. Masz uwagi, sugestie lub propozycje odcinka? Zostaw komentarz pod filmem. Dzięki za uwagę i do zobaczenia&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="4410" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-37" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" value="Satel Fire jakaś animacja wieńcząca dzieło" vertex="1">
          <mxGeometry height="60" width="700" x="4410" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-38" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;div&gt;Widok na centralę i moduł na ścianie, komentarz lektora:&lt;/div&gt;&lt;div&gt;1) Our module is now properly connected and configured&lt;/div&gt;&lt;div&gt;2) From now on, we are able to immediately recieve information about alarms and fault on supervised property&lt;/div&gt;&lt;div&gt;3) If you liked this material, leave a thumbs up. Have a suggestion, video proposition ? Leave a comment and subscribe to this channel, not to miss next episode.Stay safe and see you in the next video&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="330" x="4780" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="0qluF64Sdjj_I7BYTujH-39" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;" value="&lt;br&gt;&lt;div style=&quot;display: inline-block; font-size: 12px; font-family: Helvetica; color: light-dark(#000000, #ffffff); line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal;&quot;&gt;GSM-X, GPRS-A - connecting module to control panel ACSP-402, installation and configuration&lt;/div&gt;&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
